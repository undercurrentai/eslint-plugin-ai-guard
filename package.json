{
  "name": "eslint-plugin-ai-guard",
  "version": "1.1.9",
  "description": "ESLint plugin to catch AI-specific code patterns: missing error handling, async misuse, auth gaps, and hallucinations",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "ai",
    "llm",
    "copilot",
    "cursor",
    "claude",
    "code-quality",
    "security"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "ai-guard": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "@typescript-eslint/utils": "^8.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitepress": "^1.3.4",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@typescript-eslint/utils": "^8.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "eslint-plugin-ai-guard": "^1.1.8",
    "ora": "^9.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YashJadhav21/eslint-plugin-ai-guard"
  },
  "bugs": {
    "url": "https://github.com/YashJadhav21/eslint-plugin-ai-guard/issues"
  },
  "homepage": "https://github.com/YashJadhav21/eslint-plugin-ai-guard#readme",
  "author": "YashJadhav21",
  "license": "MIT"
}
