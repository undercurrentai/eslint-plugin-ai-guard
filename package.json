{
  "name": "@undercurrent/eslint-plugin-ai-guard",
  "version": "2.0.0-beta.1",
  "description": "Framework-deep, AI-risk-focused ESLint policy layer for agent-written JS/TS application code. Fork of eslint-plugin-ai-guard.",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "ai",
    "llm",
    "copilot",
    "cursor",
    "claude",
    "code-quality",
    "security"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "ai-guard": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "npm run build && eslint src cli tests --ext .ts",
    "init-context": "node dist/cli/index.js init-context",
    "prepublishOnly": "npm run typecheck && npm run test && npm run lint && npm run build"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@typescript-eslint/parser": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitepress": "^1.3.4",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@typescript-eslint/utils": "^8.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^8.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/undercurrentai/eslint-plugin-ai-guard"
  },
  "bugs": {
    "url": "https://github.com/undercurrentai/eslint-plugin-ai-guard/issues"
  },
  "homepage": "https://github.com/undercurrentai/eslint-plugin-ai-guard#readme",
  "author": "Undercurrent Holdings",
  "contributors": [
    "YashJadhav21 (original author)"
  ],
  "license": "MIT",
  "overrides": {
    "vite": "^6.4.2",
    "esbuild": "^0.25.0"
  }
}
